# Скопируйте в `.env` и подставьте значения. Файл `.env` не коммитится.

# Qdrant: укажите ровно один вариант подключения (или оставьте оба пустыми для дефолтов в коде).
# QDRANT_URL=http://localhost:6333
# QDRANT_PATH=./data/qdrant_storage

# QDRANT_COLLECTION_NAME=support_assistant
# EMBEDDING_VECTOR_SIZE=1024
# true = размерность берётся из ответа API после первого embed(), не сверяем с EMBEDDING_VECTOR_SIZE
# EMBEDDING_VECTOR_SIZE_FROM_API=false

# GIGACHAT_CREDENTIALS=
# GIGACHAT_SCOPE=GIGACHAT_API_PERS
# Модель эмбеддингов: Embeddings, Embeddings-2, EmbeddingsGigaR и т.д.
# GIGACHAT_EMBEDDING_MODEL=Embeddings
# GIGACHAT_VERIFY_SSL_CERTS=true
# GIGACHAT_TIMEOUT=60

# Чанкинг (AdaptiveChunker): overlap < chunk_size, chunk_min_size <= chunk_size
# CHUNK_SIZE=500
# CHUNK_OVERLAP=100
# CHUNK_MIN_SIZE=50

# RAG retrieval (QueryPipeline по умолчанию; переопределение в retrieve(...))
# SEARCH_TOP_K=5
# Порог score в Qdrant; пусто = без порога
# SEARCH_SCORE_THRESHOLD=
